<svg width="1400" height="2200" xmlns="http://www.w3.org/2000/svg">
  <style>
    text { font-family: Arial, sans-serif; font-size: 13px; }
    .title { font-size: 24px; font-weight: bold; }
    .subtitle { font-size: 16px; fill: #555; }
    .stage-box { fill: #F7F7F7; stroke: #CCCCCC; stroke-width: 1.5; rx: 14; ry: 14; }
    .stage-header { fill: #E0ECF8; stroke: #A3BDE3; stroke-width: 1.5; }
    .stage-header-text { font-size: 15px; font-weight: bold; }
    .stage-tag { font-weight: bold; fill: #333; }
    .arrow { stroke: #555; stroke-width: 2; marker-end: url(#arrowhead); }
    .note { fill: #666; font-size: 12px; font-style: italic; }
  </style>

  <defs>
    <marker id="arrowhead" markerWidth="10" markerHeight="7"
            refX="10" refY="3.5" orient="auto">
      <polygon points="0 0, 10 3.5, 0 7" fill="#555" />
    </marker>
  </defs>

  <!-- Title -->
  <text x="700" y="40" text-anchor="middle" class="title">
    KG Construction & Code Summarization Pipeline
  </text>
  <text x="700" y="65" text-anchor="middle" class="subtitle">
    From Git Repository ➜ Knowledge Graph ➜ LLM-based Code Summaries
  </text>

  <!-- Legend -->
  <rect x="60" y="85" width="380" height="80" fill="none" stroke="#CCCCCC" rx="8" ry="8"/>
  <text x="80" y="110" class="stage-tag">Legend:</text>
  <text x="80" y="130">📁 Repo / Files</text>
  <text x="220" y="130">⚙️  Scripts / Steps</text>
  <text x="80" y="150">📄 Outputs / JSON</text>
  <text x="220" y="150">🧠 KG / LLM / Summaries</text>

  <!-- Common geometry -->
  <!-- Each stage is 1100 wide, 140 high; vertical spacing ~150 -->

  <!-- STAGE 0 -->
  <g transform="translate(150,190)">
    <rect width="1100" height="140" class="stage-box"/>
    <rect width="1100" height="34" class="stage-header"/>
    <text x="10" y="23" class="stage-header-text">STAGE 0 — 📁 Repository Setup & Indexing</text>
    <text x="20" y="55" class="stage-tag">Motive:</text>
    <text x="130" y="55">Cleanly index the codebase and ensure git is available.</text>

    <text x="20" y="80" class="stage-tag">Input:</text>
    <text x="130" y="80">Git repository (source code + full history).</text>

    <text x="20" y="105" class="stage-tag">Key Scripts:</text>
    <text x="130" y="105">⚙️ step1_verify_clone.py, step2_index_repo_files.py</text>

    <text x="20" y="130" class="stage-tag">Outputs:</text>
    <text x="130" y="130">📄 file_index.json — all files (.py, docs, configs) indexed.</text>
  </g>

  <!-- Arrow 0 -> 1 -->
  <line x1="700" y1="330" x2="700" y2="350" class="arrow"/>

  <!-- STAGE 1 -->
  <g transform="translate(150,350)">
    <rect width="1100" height="160" class="stage-box"/>
    <rect width="1100" height="34" class="stage-header"/>
    <text x="10" y="23" class="stage-header-text">STAGE 1 — 📦 Artifact & Dependency Extraction</text>

    <text x="20" y="55" class="stage-tag">Motive:</text>
    <text x="130" y="55">Discover docs, archives, and embedded dependencies that influence behavior.</text>

    <text x="20" y="80" class="stage-tag">Input:</text>
    <text x="130" y="80">
      file_index.json, repository files (code, PDFs, JARs, .whl, .tar.gz, etc.).
    </text>

    <text x="20" y="105" class="stage-tag">Key Scripts:</text>
    <text x="130" y="105">
      ⚙️ stepA_generate_manifest.py, stepB_tika_extract.py,
    </text>
    <text x="130" y="125">
      ⚙️ stepC_extract_archives.py, stepD_merge_artifacts_into_manifest.py
    </text>

    <text x="20" y="150" class="stage-tag">Outputs:</text>
    <text x="130" y="150">
      📄 manifest.json (unified artifact inventory), artifacts_index.json (dependencies found).
    </text>
  </g>

  <!-- Arrow 1 -> 2 -->
  <line x1="700" y1="510" x2="700" y2="530" class="arrow"/>

  <!-- STAGE 2 -->
  <g transform="translate(150,530)">
    <rect width="1100" height="170" class="stage-box"/>
    <rect width="1100" height="34" class="stage-header"/>
    <text x="10" y="23" class="stage-header-text">STAGE 2 — 🧩 Code Entity Extraction & Symbol Resolution</text>

    <text x="20" y="55" class="stage-tag">Motive:</text>
    <text x="130" y="55">
      Build a canonical registry of functions, classes, methods, and variables with precise locations.
    </text>

    <text x="20" y="80" class="stage-tag">Input:</text>
    <text x="130" y="80">
      Source code (.py files), manifest.json, file_index.json.
    </text>

    <text x="20" y="105" class="stage-tag">Key Scripts:</text>
    <text x="130" y="105">
      ⚙️ step3_extract_code_entities.py, step3_enrich_code_entities_with_source.py,
    </text>
    <text x="130" y="125">
      ⚙️ step3_write_full_code_entities.py, stepG_build_symbol_table.py
    </text>

    <text x="20" y="150" class="stage-tag">Outputs:</text>
    <text x="130" y="150">
      📄 code_entities.json, code_entities_full.json, symbol_table.json,
      module_index.json, module_defs.json.
    </text>
  </g>

  <!-- Arrow 2 -> 3 -->
  <line x1="700" y1="700" x2="700" y2="720" class="arrow"/>

  <!-- STAGE 3 -->
  <g transform="translate(150,720)">
    <rect width="1100" height="190" class="stage-box"/>
    <rect width="1100" height="34" class="stage-header"/>
    <text x="10" y="23" class="stage-header-text">STAGE 3 — 🔗 Call & Dependency Graph Construction</text>

    <text x="20" y="55" class="stage-tag">Motive:</text>
    <text x="130" y="55">
      Model how code pieces interact: who calls whom, and which files/modules depend on which.
    </text>

    <text x="20" y="80" class="stage-tag">Input:</text>
    <text x="130" y="80">
      symbol_table.json, code_entities_full.json, source code, manifest.json.
    </text>

    <text x="20" y="105" class="stage-tag">Key Scripts:</text>
    <text x="130" y="105">
      ⚙️ stepH_build_call_graph.py, stepH_full_call_graph.py,
      stepN_build_file_dependency_graph.py,
    </text>
    <text x="130" y="125">
      ⚙️ stepM_enrich_call_graph_with_jedi.py, stepJ_parse_dependencies.py
    </text>

    <text x="20" y="150" class="stage-tag">Outputs:</text>
    <text x="130" y="150">
      📄 call_graph.json, call_graph_enriched.json, file_dependency_graph.json,
      file_dependency_matrix.json,
    </text>
    <text x="130" y="170">
      📄 dependencies.json, dependencies_by_file.json, import_aliases.json.
    </text>
  </g>

  <!-- Arrow 3 -> 4 -->
  <line x1="700" y1="910" x2="700" y2="930" class="arrow"/>

  <!-- STAGE 4 -->
  <g transform="translate(150,930)">
    <rect width="1100" height="180" class="stage-box"/>
    <rect width="1100" height="34" class="stage-header"/>
    <text x="10" y="23" class="stage-header-text">STAGE 4 — 🧾 Provenance & Metadata Enrichment</text>

    <text x="20" y="55" class="stage-tag">Motive:</text>
    <text x="130" y="55">
      Link code entities to their git history: commits, authors, PRs, timestamps.
    </text>

    <text x="20" y="80" class="stage-tag">Input:</text>
    <text x="130" y="80">
      symbol_table.json, code_entities_full.json, git history (commits, PRs).
    </text>

    <text x="20" y="105" class="stage-tag">Key Scripts:</text>
    <text x="130" y="105">
      ⚙️ stepI_map_functions_to_commits.py, stepP_enrich_with_commits.py
    </text>

    <text x="20" y="130" class="stage-tag">Outputs:</text>
    <text x="130" y="130">
      📄 function_commits.json, function_commits_repaired.json,
      commits.json, pull_requests.json,
    </text>
    <text x="130" y="150">
      📄 commit_to_prs.json, nodes_with_commit.json (nodes annotated with commit provenance).
    </text>
  </g>

  <!-- Arrow 4 -> 5 -->
  <line x1="700" y1="1110" x2="700" y2="1130" class="arrow"/>

  <!-- STAGE 5 -->
  <g transform="translate(150,1130)">
    <rect width="1100" height="180" class="stage-box"/>
    <rect width="1100" height="34" class="stage-header"/>
    <text x="10" y="23" class="stage-header-text">STAGE 5 — 🛠 Configuration & CI/CD Analysis</text>

    <text x="20" y="55" class="stage-tag">Motive:</text>
    <text x="130" y="55">
      Understand deployment context, environments, and secrets from configs & CI workflows.
    </text>

    <text x="20" y="80" class="stage-tag">Input:</text>
    <text x="130" y="80">
      file_index.json, configs (.yaml, .json, .env, Dockerfile, CI workflows).
    </text>

    <text x="20" y="105" class="stage-tag">Key Scripts:</text>
    <text x="130" y="105">
      ⚙️ stepK_parse_ci_workflows.py, stepL_parse_configs_and_detect_secrets.py
    </text>

    <text x="20" y="130" class="stage-tag">Outputs:</text>
    <text x="130" y="130">
      📄 ci_workflows.json, configs.json,
      ci_env_secrets_report.json, configs_secrets_report.json.
    </text>
  </g>

  <!-- Arrow 5 -> 6 -->
  <line x1="700" y1="1310" x2="700" y2="1330" class="arrow"/>

  <!-- STAGE 6 -->
  <g transform="translate(150,1330)">
    <rect width="1100" height="160" class="stage-box"/>
    <rect width="1100" height="34" class="stage-header"/>
    <text x="10" y="23" class="stage-header-text">STAGE 6 — 📚 Dependency Parsing & Resolution</text>

    <text x="20" y="55" class="stage-tag">Motive:</text>
    <text x="130" y="55">
      Capture external libraries and packages used by the project.
    </text>

    <text x="20" y="80" class="stage-tag">Input:</text>
    <text x="130" y="80">
      manifest.json, requirements.txt, setup.py, pom.xml, Gemfile, package.json, etc.
    </text>

    <text x="20" y="105" class="stage-tag">Key Scripts:</text>
    <text x="130" y="105">
      ⚙️ stepJ_parse_dependencies.py
    </text>

    <text x="20" y="130" class="stage-tag">Outputs:</text>
    <text x="130" y="130">
      📄 dependencies.json (package-level), reuse import_aliases.json from Stage 3.
    </text>
  </g>

  <!-- Arrow 6 -> 7 -->
  <line x1="700" y1="1490" x2="700" y2="1510" class="arrow"/>

  <!-- STAGE 7 -->
  <g transform="translate(150,1510)">
    <rect width="1100" height="180" class="stage-box"/>
    <rect width="1100" height="34" class="stage-header"/>
    <text x="10" y="23" class="stage-header-text">STAGE 7 — 🕸 KG Merge & Schema Construction</text>

    <text x="20" y="55" class="stage-tag">Motive:</text>
    <text x="130" y="55">
      Merge all extracted signals into a single, coherent knowledge graph.
    </text>

    <text x="20" y="80" class="stage-tag">Input:</text>
    <text x="130" y="80">
      code_entities, symbol_table, call graphs, dependency graphs, configs, commits, PRs.
    </text>

    <text x="20" y="105" class="stage-tag">Key Scripts:</text>
    <text x="130" y="105">
      ⚙️ stepO_merge_into_kg.py
    </text>

    <text x="20" y="130" class="stage-tag">Outputs:</text>
    <text x="130" y="130">
      📄 node_v2.json (KG nodes), edges.json (KG edges), kg_schema.json (ontology/schema).
    </text>
  </g>

  <!-- Arrow 7 -> 8 -->
  <line x1="700" y1="1690" x2="700" y2="1710" class="arrow"/>

  <!-- STAGE 8 -->
  <g transform="translate(150,1710)">
    <rect width="1100" height="190" class="stage-box"/>
    <rect width="1100" height="34" class="stage-header"/>
    <text x="10" y="23" class="stage-header-text">STAGE 8 — 🧠 Node Enrichment & Disambiguation</text>

    <text x="20" y="55" class="stage-tag">Motive:</text>
    <text x="130" y="55">
      Improve node quality: resolve ambiguities, backfill missing attributes, add embeddings.
    </text>

    <text x="20" y="80" class="stage-tag">Input:</text>
    <text x="130" y="80">
      node_v2.json, edges.json, AST data, call graph data, text search results.
    </text>

    <text x="20" y="105" class="stage-tag">Key Scripts:</text>
    <text x="130" y="105">
      ⚙️ stepQ_enrich_nodes_extended.py (and helpers for disambiguation/backfilling)
    </text>

    <text x="20" y="130" class="stage-tag">Outputs:</text>
    <text x="130" y="130">
      📄 nodes_resolved.json, nodes_disambiguated.json,
      nodes_ast_backfilled.json,
    </text>
    <text x="130" y="150">
      📄 nodes_callgraph_backfilled.json, nodes_textsearch_backfilled.json.
    </text>
  </g>

  <!-- Arrow 8 -> 9 -->
  <line x1="700" y1="1900" x2="700" y2="1920" class="arrow"/>

  <!-- STAGE 9 -->
  <g transform="translate(150,1920)">
    <rect width="1100" height="160" class="stage-box"/>
    <rect width="1100" height="34" class="stage-header"/>
    <text x="10" y="23" class="stage-header-text">STAGE 9 — 📤 Final KG Export & QA</text>

    <text x="20" y="55" class="stage-tag">Motive:</text>
    <text x="130" y="55">
      Produce consumable KG formats and a quality report for analysis & loading into graph DBs.
    </text>

    <text x="20" y="80" class="stage-tag">Input:</text>
    <text x="130" y="80">
      node_v2.json, edges.json, kg_schema.json, enriched node variants.
    </text>

    <text x="20" y="105" class="stage-tag">Outputs:</text>
    <text x="130" y="105">
      📄 kg_nodes.csv, kg_edges.csv (tabular), kg_report.json (QA metrics),
      FINAL KG (Neo4j / RDF / JSON).
    </text>
  </g>

  <!-- Arrow 9 -> 10 -->
  <line x1="700" y1="2080" x2="700" y2="2100" class="arrow"/>

  <!-- STAGE 10 -->
  <g transform="translate(150,2100)">
    <rect width="1100" height="160" class="stage-box"/>
    <rect width="1100" height="34" class="stage-header"/>
    <text x="10" y="23" class="stage-header-text">STAGE 10 — 🧠➜📝 KG-Aware Code Summarization</text>

    <text x="20" y="55" class="stage-tag">Motive:</text>
    <text x="130" y="55">
      Use KG facts as structured context to guide LLM-based code summaries.
    </text>

    <text x="20" y="80" class="stage-tag">Input:</text>
    <text x="130" y="80">
      FINAL KG (nodes & edges), source code snippets, user query.
    </text>

    <text x="20" y="105" class="stage-tag">Key Artifacts:</text>
    <text x="130" y="105">
      📄 summarizer_request.json — packaged KG context (callers, callees, commits, configs).
    </text>

    <text x="20" y="130" class="stage-tag">Outputs:</text>
    <text x="130" y="130">
      🧠 LLM → 📝 Generated code summaries grounded in KG (explainable & traceable).
    </text>
  </g>

</svg>
